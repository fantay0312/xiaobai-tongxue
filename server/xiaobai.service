[Unit]
Description=Xiaobai classmate gateway (static + auth + LLM proxy)
After=network.target

[Service]
Type=simple
User=xiaobai
Group=xiaobai
WorkingDirectory=/opt/xiaobai/server
# 可选密钥文件(0600,root 持有):RESEND_API_KEY=... / RESEND_FROM=...
EnvironmentFile=-/etc/xiaobai/xiaobai.env
ExecStart=/usr/bin/node /opt/xiaobai/server/index.mjs
Restart=always
RestartSec=3
AmbientCapabilities=CAP_NET_BIND_SERVICE
NoNewPrivileges=true
ProtectSystem=strict
ReadOnlyPaths=/opt/xiaobai
# 注册用户、邮箱/密码覆盖与学习存档的唯一可写处(/var/lib/xiaobai,自动建目录并授权 User);
# 代码与配置所在的 /opt/xiaobai 保持只读,config.json 须配 dataDir=/var/lib/xiaobai
StateDirectory=xiaobai
PrivateTmp=true

[Install]
WantedBy=multi-user.target
